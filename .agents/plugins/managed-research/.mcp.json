{
  "mcpServers": {
    "managed-research": {
      "command": "uv",
      "args": [
        "run",
        "--quiet",
        "managed-research-mcp"
      ],
      "cwd": "../../../../managed-research",
      "env_vars": [
        "SYNTH_API_KEY",
        "SYNTH_BACKEND_URL"
      ],
      "startup_timeout_sec": 20,
      "tool_timeout_sec": 180
    }
  }
}
